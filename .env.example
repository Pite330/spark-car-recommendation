# Optional LLM explanation layer. Core recommendations work when disabled.
LLM_ENABLED=false
LLM_PROVIDER=deepseek
LLM_TIMEOUT_SECONDS=8

# Use 0.0.0.0 with an unused port when devices on the same LAN need access.
APP_HOST=127.0.0.1
APP_PORT=5000

# DeepSeek official API. Prefer storing the key in an ignored .env or a private file.
DEEPSEEK_API_BASE=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_API_KEY=
# DEEPSEEK_API_KEY_FILE=/Users/your-name/.secrets/deepseek-api-key

# Alternative OpenAI-compatible provider:
# LLM_PROVIDER=openai_compatible
# LLM_API_BASE=https://provider.example/v1
# LLM_MODEL=model-name
# LLM_API_KEY=
# LLM_API_KEY_FILE=/absolute/path/to/private-key-file
